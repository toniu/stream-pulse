# Environment Configuration for pyAux
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_ENV=development  # Options: development, production, testing
FLASK_SECRET_KEY=your-secret-key-here-change-in-production
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# Spotify API Credentials
# Get these from: https://developer.spotify.com/dashboard
CLIENT_ID=your_spotify_client_id
CLIENT_SECRET=your_spotify_client_secret

# Application Settings
MAX_PLAYLIST_SIZE=1000
REQUEST_TIMEOUT=30

# Caching (optional - defaults to simple in-memory cache)
CACHE_TYPE=simple  # Options: simple, redis
CACHE_TIMEOUT=300

# Logging
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# CORS (comma-separated list, or * for all origins)
CORS_ORIGINS=*

# Redis Configuration (if using Redis cache)
# REDIS_URL=redis://localhost:6379/0
